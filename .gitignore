# =============================================================================
# BuildEstimate — Construction Estimating Software
# .gitignore — Files and directories excluded from version control
# =============================================================================

# =============================================================================
# C# / .NET — Build outputs and user-specific IDE files
# These directories are regenerated every time you build — no need to commit.
# =============================================================================

# Compiled output directories (MSBuild generates these)
bin/
obj/

# Visual Studio user-specific settings (machine-specific, never share these)
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio hidden folder (IDE state, breakpoints, recently opened files)
.vs/

# NuGet package files (restored via "dotnet restore", not committed)
*.nupkg
*.snupkg
packages/
!*.nuspec

# Publish output (generated by "dotnet publish")
publish/

# Entity Framework Core migration snapshots (generated code, sometimes committed
# but ignored here to avoid conflicts in team environments)
# Uncomment the next line ONLY if you want to exclude migration snapshots:
# **/Migrations/*Snapshot.cs

# ASP.NET Core secrets and environment-specific config files
# WARNING: These may contain real database connection strings or API keys!
appsettings.Development.json
appsettings.Local.json
appsettings.Production.json
appsettings.Staging.json

# =============================================================================
# Node.js / TypeScript — Frontend dependencies and build output
# "node_modules" contains thousands of files — always install via "npm install"
# =============================================================================

# Installed npm packages (re-run "npm install" to restore)
node_modules/

# TypeScript/Vite compiled output
dist/
build/
.next/
out/

# Environment variable files (may contain API keys, secrets — NEVER commit!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# npm and yarn log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test coverage reports
coverage/
*.lcov
.nyc_output

# =============================================================================
# OS-generated files — Created by the operating system, not by your project
# =============================================================================

# macOS metadata files (created by Finder)
.DS_Store
.AppleDouble
.LSOverride

# Windows thumbnail cache and desktop settings
Thumbs.db
Thumbs.db:encdata
ehthumbs.db
Desktop.ini

# Windows Explorer shortcuts
*.lnk

# Linux trash directory
.Trash-*

# =============================================================================
# IDE and Editor files — Workspace settings that are personal to each developer
# =============================================================================

# JetBrains IDEs (Rider, IntelliJ, WebStorm, etc.)
.idea/
*.iml
*.iws

# Visual Studio Code — exclude workspace settings (but keep extensions.json,
# which recommends extensions to other developers on the team)
.vscode/*
!.vscode/extensions.json

# Sublime Text project files
*.sublime-project
*.sublime-workspace

# Vim swap files
*.swp
*.swo
*~

# =============================================================================
# Logging — Application log files generated at runtime
# =============================================================================
*.log
logs/

# =============================================================================
# Miscellaneous
# =============================================================================

# Temporary files
*.tmp
*.temp
*.bak
*.orig

# Docker (if used locally for testing)
.dockerignore
